--Loome uue Sale (idSALE, idProduct, idCustomer, Count_pr, Date_of_sale)
CREATE TABLE Sale(
idSale int Primary key identity(1,1),
idProduct int,
Foreign Key (idProduct)References Product(idProduct),
idCustomer int, 
count_pr int,
date_of_sale date)

