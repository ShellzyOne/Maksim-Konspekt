--Loome uues Producti (Product (idProduct, Name, IdCategory)
CREATE TABLE Product(
idProduct int Primary Key identity(1,1),
Name varchar(25),
idCategory int, 
Foreign Key(idCategory) References Catergory(idCategory),
Price money)

